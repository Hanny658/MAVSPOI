OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# Optional OpenAI-compatible API endpoint for non-OpenAI providers
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# Optional port override. If OPENAI_BASE_URL has no explicit port, this port will be injected.
# If OPENAI_BASE_URL is empty and this is set, default base URL becomes http://127.0.0.1:<PORT>/v1
# OPENAI_API_PORT=11434

# Optional runtime config (default: config.yaml) for experiments
# CONFIG_YAML_PATH=config.yaml
