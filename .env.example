OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small


# ====================== Optional config ======================

# Train split paths produced by utils/build_eval_protocol.py
# (kept under data/train/)
YELP_BUSINESS_JSON=data/train/yelp-indianapolis-train-business.jsonl
YELP_PROFILE_JSON=data/train/yelp-indianapolis-train-profile.jsonl

# Evaluation artifacts (kept under data/eval/, not consumed by runtime pipeline)
# data/eval/yelp-indianapolis-eval-queries.jsonl
# data/eval/yelp-indianapolis-eval-candidates.jsonl

# Build-size controls
YELP_MAX_BUSINESSES=50000
YELP_CITY_FILTER=

# Retrieval and recommendation controls
RETRIEVAL_TOP_K=80
FORECASTER_TOP_K=25
FINAL_TOP_K=10

# Embedding cache
EMBED_CACHE_PATH=data/cache/yelp-indianapolis-train-business-embeddings.jsonl
